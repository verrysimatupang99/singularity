{
  "name": "singularity",
  "version": "1.0.0",
  "description": "Multi-provider AI coding agent desktop app",
  "type": "module",
  "main": "dist/main/index.js",
  "author": {
    "name": "Verry",
    "email": "34811528+verrysimatupang99@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "npm run build && electron-builder --config electron-builder.config.cjs",
    "package:linux": "npm run build && electron-builder --linux --config electron-builder.config.cjs",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.config.cjs",
    "package:win": "npm run build && electron-builder --win --config electron-builder.config.cjs",
    "release": "npm run build && electron-builder --publish=always --config electron-builder.config.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-virtual": "^3.13.23",
    "diff": "^8.0.4",
    "electron-log": "^5.2.4",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.503.0",
    "marked": "^15.0.11",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "openai": "^4.96.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "34.3.2",
    "electron-builder": "^25.1.8",
    "eslint": "^9.11.1",
    "eslint-plugin-react": "^7.37.5",
    "happy-dom": "^20.8.9",
    "typescript": "^5.8.0",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  }
}
